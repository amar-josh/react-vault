{
  "name": "@rsense/create-bfsi-app",
  "version": "0.1.0",
  "description": "Scaffold a new Rsense BFSI React project. Pick a state-management variant (RTK Query or TanStack Query) and get a production-ready starter with security, audit, encryption, and Claude Code companion baked in.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "create-bfsi-app": "./bin/create-bfsi-app.js",
    "create-rsense-bfsi-app": "./bin/create-bfsi-app.js"
  },
  "main": "./dist/index.js",
  "files": ["bin", "dist", "templates", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "picocolors": "catalog:",
    "fs-extra": "catalog:",
    "commander": "catalog:",
    "execa": "catalog:"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/fs-extra": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
