{
  "name": "@scope/create-app",
  "version": "0.1.0",
  "description": "Scaffold a new Your Org BFSI React project. Pick a state-management variant (RTK Query or TanStack Query) and get a production-ready starter with security, audit, encryption, and Claude Code companion baked in.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "create-app": "./bin/create-app.js",
    "create-scoped-app": "./bin/create-app.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tsbuildinfo",
    "pack:local": "node ../../scripts/pack-cli-with-templates.mjs"
  },
  "dependencies": {
    "@clack/prompts": "0.7.0",
    "picocolors": "1.0.0",
    "fs-extra": "11.2.0",
    "commander": "12.0.0",
    "execa": "9.0.2"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/fs-extra": "11.0.4",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
