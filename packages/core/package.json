{
  "name": "@react-vault/core",
  "version": "0.1.0",
  "description": "Core BFSI security primitives: encryption, PII masking, audit logging, secure storage, auth, axios factory. Framework-agnostic.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "import": "./dist/encryption/index.js"
    },
    "./pii": {
      "types": "./dist/pii/index.d.ts",
      "import": "./dist/pii/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./compliance": {
      "types": "./dist/compliance/index.d.ts",
      "import": "./dist/compliance/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "axios": "1.6.8",
    "zod": "3.23.6"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "jsdom": "24.0.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amar-josh/react-vault.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/amar-josh/react-vault#readme",
  "bugs": {
    "url": "https://github.com/amar-josh/react-vault/issues"
  },
  "keywords": [
    "bfsi",
    "fintech",
    "encryption",
    "pii",
    "audit",
    "rbi",
    "pci-dss",
    "axios",
    "secure-storage"
  ],
  "publishConfig": {
    "access": "public"
  }
}
